# Librarian — Bright Data credentials for `librarian sync` enrichment.
#
# Copy to /etc/librarian/.env (mode 0640, root:librarian) and fill in your zone keys.
# Without these, `sync` falls back to local rescan only — every other command continues
# to work. Variable names match the OmniScan project's .env so you can copy-paste.

# Bright Data API key (account-wide; single key drives both zones).
BRIGHT_DATA_API_KEY=

# Zone names — defaults match the OmniScan project's existing zones.
BRIGHT_DATA_UNLOCKER_ZONE=omniscan_unlocker
BRIGHT_DATA_SERP_ZONE=omniscan_serp

# Optional knobs ---------------------------------------------------------------
# Cap enrichment requests per `librarian sync` run (default 100).
# LIBRARIAN_ENRICH_MAX=100

# Sleep between SERP requests in milliseconds (default 200, polite rate-limit).
# LIBRARIAN_ENRICH_DELAY_MS=200

# Enrichment cache TTL in seconds (default 2592000 = 30 days).
# LIBRARIAN_ENRICH_TTL=2592000
